# ─── Supabase ────────────────────────────────────────────────────────────────
# Use the SERVICE ROLE key (not the anon key) so the script can bypass RLS
SUPABASE_URL=https://lteogzqeuuoxlekhofow.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=fa92fb66bb8615279773847f8aecae0c
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_BUCKET_NAME=eventcast-media
# The public bucket URL (enable public access on the R2 bucket in the CF dashboard)
R2_PUBLIC_URL=https://pub-fa013cc979d8410e9d307bd2c9e6ecf2.r2.dev
# S3 key prefix — VODs will be stored at R2_PUBLIC_URL/vods/<slug>.mp4
R2_KEY_PREFIX=vods

# ─── Restreamer (Datarhei) ───────────────────────────────────────────────────
# Host path that maps to the Docker volume where Restreamer writes HLS files.
# Inside the container this is /data; on the host this is the mount point.
RESTREAMER_DATA_DIR=/opt/restreamer/data

# ─── FFmpeg ──────────────────────────────────────────────────────────────────
# Full path to ffmpeg binary if not on $PATH
FFMPEG_BIN=ffmpeg

# ─── Archiver internals ──────────────────────────────────────────────────────
# Temp directory for MP4 files during stitching (needs enough free disk space)
TEMP_DIR=/tmp/vod-archiver
# PID lock file — prevents multiple concurrent instances
LOCK_FILE=/tmp/vod-archiver.lock
# Optional: write JSON logs to a file in addition to stdout
# LOG_FILE=/var/log/vod-archiver.log
# How long (ms) a 'processing' sentinel is considered stale before auto-reset
# Default: 14400000 = 4 hours
STALE_THRESHOLD_MS=14400000
